{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "name": "semver-context",
            "type": "command",
            "command": "DIR=$(printf %s \"${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-${extensionPath}}}\" | tr '\\\\' '/'); node \"${DIR}/hooks/semver-context.js\" SessionStart",
            "commandWindows": "$root = if ($env:CODEX_PLUGIN_ROOT) { $env:CODEX_PLUGIN_ROOT } elseif ($env:CLAUDE_PLUGIN_ROOT) { $env:CLAUDE_PLUGIN_ROOT } else { $env:extensionPath }; node \"$root\\hooks\\semver-context.js\" SessionStart",
            "timeout": 5,
            "statusMessage": "Loading SemVer rules..."
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "name": "semver-context",
            "type": "command",
            "command": "DIR=$(printf %s \"${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-${extensionPath}}}\" | tr '\\\\' '/'); node \"${DIR}/hooks/semver-context.js\" SubagentStart",
            "commandWindows": "$root = if ($env:CODEX_PLUGIN_ROOT) { $env:CODEX_PLUGIN_ROOT } elseif ($env:CLAUDE_PLUGIN_ROOT) { $env:CLAUDE_PLUGIN_ROOT } else { $env:extensionPath }; node \"$root\\hooks\\semver-context.js\" SubagentStart",
            "timeout": 5,
            "statusMessage": "Loading SemVer rules..."
          }
        ]
      }
    ]
  }
}
